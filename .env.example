# Environment variables template
# Copy to .env and fill in values

# ============================================================================
# ENVIRONMENT
# ============================================================================
# Target environment: dev | staging | prod
ENVIRONMENT=dev

# ============================================================================
# PROVIDER
# ============================================================================
# LLM provider: groq | ollama
PROVIDER=groq

# ============================================================================
# GROQ CONFIG (Google SDET: use secret rotation in production)
# ============================================================================
# Get your API key from https://console.groq.com
GROQ_API_KEY=

# Optional: Use multiple keys for rotation (comma-separated)
# GROQ_API_KEYS=key1,key2,key3

# Model selection (varies by environment)
LLM_MODEL=llama-3.1-8b-instant

# ============================================================================
# OLLAMA CONFIG
# ============================================================================
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=llama3.2:1b

# ============================================================================
# TEST CONFIGURATION
# ============================================================================
# Test scenario: baseline | load | stress
TEST_SCENARIO=baseline

# ============================================================================
# OBSERVABILITY
# ============================================================================
# Enable Prometheus export
PROMETHEUS_ENABLED=false

# DataDog integration (optional)
DATADOG_API_KEY=
DATADOG_ENABLED=false

# ============================================================================
# SLO THRESHOLDS (Google SDET: define in environments.js)
# ============================================================================
ERROR_BUDGET=0.05
LATENCY_P95_TARGET=2000
SUCCESS_RATE_TARGET=0.95
